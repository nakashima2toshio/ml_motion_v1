# Phase 0: 環境変数テンプレート。`.env` にコピーして値を設定する。
# cp .env.example .env

# Anthropic Claude API（Vision・要約・アノテ補助）。Phase 6 で使用。
ANTHROPIC_API_KEY=your-anthropic-api-key

# 既定モデル（最新世代）。コストに応じて軽量モデルへ切替可能。
ANTHROPIC_MODEL=claude-opus-4-8

# MLflow Tracking サーバ（docker-compose で起動）。
# 別アプリが 5000 を使用中で衝突する場合は MLFLOW_PORT を変更し、
# MLFLOW_TRACKING_URI のポートも合わせて更新する（例: 5001）。
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
